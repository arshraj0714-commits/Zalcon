# Zalcon — environment configuration
# Copy this file to .env and fill in your values.

# REQUIRED: your Discord bot token
TOKEN=PUT_YOUR_BOT_TOKEN_HERE

# REQUIRED: your bot's application/client ID (for slash command registration)
CLIENT_ID=PUT_YOUR_CLIENT_ID_HERE

# Command prefix (default: -)
PREFIX=-

# Comma-separated list of owner user IDs (for developer commands)
OWNER_IDS=

# Discord presence
STATUS=online
ACTIVITY_TYPE=WATCHING
ACTIVITY_NAME=Zalcon | -help

# Register slash commands globally (true) or per-guild for fast testing (false)
GLOBAL_SLASH=true

# Accounts younger than this many days are treated as "fake" invites
FAKE_ACCOUNT_AGE_DAYS=7

# Optional: MongoDB URI (if unset, a local JSON database under ./data is used)
# MONGO_URI=
